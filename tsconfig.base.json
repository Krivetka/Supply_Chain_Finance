{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@scf/shared/kernel": ["libs/shared/kernel/src/index.ts"],
      "@scf/invoicing/domain": ["libs/invoicing/domain/src/index.ts"],
      "@scf/invoicing/data-access": ["libs/invoicing/data-access/src/index.ts"],
      "@scf/invoicing/ui": ["libs/invoicing/ui/src/index.ts"],
      "@scf/invoicing/feature-list": ["libs/invoicing/feature-list/src/index.ts"],
      "@scf/auth/data-access": ["libs/auth/data-access/src/index.ts"]
    }
  }
}
